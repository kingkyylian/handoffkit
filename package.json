{
  "name": "@kingkyylian/handoffkit",
  "version": "0.1.0",
  "description": "Local-first CLI that turns messy AI-assisted coding sessions into safe handoff packets.",
  "type": "module",
  "license": "MIT",
  "author": "Kyylian",
  "keywords": [
    "ai",
    "agent",
    "cli",
    "codex",
    "claude",
    "cursor",
    "gemini",
    "handoff",
    "local-first",
    "typescript"
  ],
  "homepage": "https://github.com/kingkyylian/handoffkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kingkyylian/handoffkit.git"
  },
  "bugs": {
    "url": "https://github.com/kingkyylian/handoffkit/issues"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "handoffkit": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "build": "tsup",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "dev": "tsup --silent && node dist/index.js",
    "lint": "eslint .",
    "pack:dry-run": "npm --cache ./.npm-cache pack --dry-run",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "execa": "^9.6.0",
    "fast-glob": "^3.3.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
